DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"

BETTER_AUTH_SECRET="replace-with-a-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DOCS_URL="https://docs.hostartifacts.dev"
MINTLIFY_DOCS_URL="http://127.0.0.1:3002"
INTERNAL_API_URL="http://127.0.0.1:3001"

# Optional CLI-only overrides (otherwise `bun run cli:build:prod` uses INTERNAL_API_URL + PUBLIC_APP_URL)
# AGENT_ARTIFACTS_BASE_URL="https://api.example.com"
# AGENT_ARTIFACTS_WEB_URL="https://example.com"

ARTIFACT_RENDER_ORIGIN="http://localhost:3001"

S3_ENDPOINT="https://account-id.r2.cloudflarestorage.com"
S3_BUCKET="agent-artifacts"
S3_REGION="auto"
S3_ACCESS_KEY_ID="your-s3-access-key-id"
S3_SECRET_ACCESS_KEY="your-s3-secret-access-key"

# Dodo Payments billing (test mode by default)
# Create these products/meters in Dodo dashboard, then copy product IDs here.
DODO_PAYMENTS_API_KEY="sk_test_xxxxx"
DODO_PAYMENTS_WEBHOOK_SECRET="whsec_xxxxx"
DODO_PAYMENTS_ENVIRONMENT="test_mode"
DODO_BUILDER_PRODUCT_ID="prod_builder"
DODO_STUDIO_PRODUCT_ID="prod_studio"
# Bearer token for scheduled storage GB-day snapshots.
BILLING_CRON_SECRET="replace-with-a-random-cron-secret"
# Run the daily storage-metering scheduler inside the API process. Enable on the
# API service ONLY (never the web service). A Postgres advisory lock makes this
# safe across multiple API replicas — only one wins each run — so leave it on the
# API even when scaling out. Defaults to false.
# ENABLE_BILLING_CRON="true"

# Set to "true" when the API runs behind a trusted reverse proxy (nginx, Cloudflare, etc.)
# so rate limiting uses cf-connecting-ip / x-real-ip / x-forwarded-for. Leave unset in local dev.
# TRUST_PROXY="true"

# Better Stack (optional — logs still go to stdout when unset)
# API server-side logs (@logtail/node)
# BETTER_STACK_SOURCE_TOKEN=""
# BETTER_STACK_INGESTING_URL="https://in.logs.betterstack.com"
# Web server-side logs (@logtail/next reads BETTER_STACK_SOURCE_TOKEN or BETTER_STACK_WEB_SOURCE_TOKEN)
# BETTER_STACK_WEB_SOURCE_TOKEN=""
# Browser logs (@logtail/next proxy)
# NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN=""
# NEXT_PUBLIC_BETTER_STACK_INGESTING_URL="https://in.logs.betterstack.com"
# Salt for hashing client IPs in logs when TRUST_PROXY=true (optional in dev)
# LOG_IP_SALT=""
# Rate limits use Postgres in production by default. Set to "memory" only for single-instance deployments.
# RATE_LIMIT_STORE="database"

# auth.md agent registration (disabled by default)
# AUTH_MD_ENABLED="false"
# AUTH_MD_SIGNING_SECRET="replace-with-a-random-32-byte-secret"
# AUTH_MD_CLAIM_TTL_SECONDS="600"
# AUTH_MD_ACCESS_TOKEN_TTL_SECONDS="900"
# AUTH_MD_PRE_CLAIM_ACCESS_TOKEN_TTL_SECONDS="300"
# AUTH_MD_IDENTITY_ASSERTION_TTL_SECONDS="300"
# AUTH_MD_ALLOWED_SCOPES="artifacts:read,artifacts:create,artifacts:update,artifacts:delete,artifacts:share,artifacts:access:read,artifacts:access:write,agents:manage"
# AUTH_MD_ANONYMOUS_PRE_CLAIM_SCOPES="artifacts:read"
# Future cron heartbeats — wire when scheduled jobs exist
# BETTER_STACK_HEARTBEAT_URL_EXAMPLE="https://uptime.betterstack.com/api/v1/heartbeat/..."
