{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Artifacts",
  "colors": {
    "primary": "#FF570A",
    "light": "#FF8A3D",
    "dark": "#FF570A"
  },
  "logo": {
    "light": "/brand/artifacts-logo.svg",
    "dark": "/brand/artifacts-logo.svg",
    "href": "/"
  },
  "favicon": "/brand/artifacts-logo.svg",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "family": "Geist",
    "source": "/fonts/Geist-Variable.woff2",
    "format": "woff2",
    "weight": 400,
    "body": {
      "family": "Geist",
      "source": "/fonts/Geist-Variable.woff2",
      "format": "woff2",
      "weight": 400
    },
    "heading": {
      "family": "Geist Pixel Square",
      "source": "/fonts/GeistPixel-Square.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "color": {
      "light": "#1B1B1B",
      "dark": "#1B1B1B"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": false,
    "codeblocks": {
      "theme": "github-dark"
    }
  },
  "thumbnails": {
    "appearance": "dark",
    "fonts": {
      "family": "Geist"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get started",
            "icon": "rocket",
            "pages": [
              "index",
              "getting-started/quickstart"
            ]
          },
          {
            "group": "Core concepts",
            "icon": "compass",
            "pages": [
              "concepts/artifacts",
              "concepts/workspaces-projects",
              "concepts/access-model"
            ]
          },
          {
            "group": "Task guides",
            "icon": "list-checks",
            "pages": [
              "guides/publish-artifact",
              "guides/version-history",
              "guides/sharing-and-permissions",
              "guides/auth-md-agent-registration",
              "guides/api-keys-and-automation"
            ]
          },
          {
            "group": "Ways to connect",
            "icon": "blocks",
            "pages": [
              "surfaces/web",
              "surfaces/cli",
              "surfaces/rest-api",
              "surfaces/mcp"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "Interfaces",
            "icon": "terminal",
            "pages": [
              "reference/cli",
              "reference/rest-api",
              "reference/mcp"
            ]
          },
          {
            "group": "Operations",
            "icon": "settings-2",
            "pages": [
              "reference/configuration",
              "reference/development"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/laxman-patel/agent-artifacts",
        "icon": "github"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://hostartifacts.dev"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/laxman-patel/agent-artifacts"
    }
  }
}
