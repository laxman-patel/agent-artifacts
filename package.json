{
  "name": "agent-artifacts",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "infisical run --env=dev -- turbo run dev --filter=@agent-artifacts/web --filter=@agent-artifacts/api",
    "dev:env-file": "bun --env-file=.env x turbo run dev --filter=@agent-artifacts/web --filter=@agent-artifacts/api",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "docs:dev": "cd docs && bunx mintlify dev --port 3002 --no-open",
    "db:generate": "infisical run --env=dev -- bun run --filter @agent-artifacts/db db:generate",
    "db:generate:env-file": "bun --env-file=.env run --filter @agent-artifacts/db db:generate",
    "db:migrate": "infisical run --env=dev -- bun run --filter @agent-artifacts/db db:migrate",
    "db:migrate:env-file": "bun --env-file=.env run --filter @agent-artifacts/db db:migrate",
    "cli:build": "bun run --filter @agent-artifacts/cli build",
    "cli:build:prod": "infisical run --env=prod --path=/shared --path=/api -- bun run --filter @agent-artifacts/cli build:prod",
    "cli:build:prod:env-file": "bun --env-file=.env run --filter @agent-artifacts/cli build:prod",
    "cli:build:release": "infisical run --env=prod --path=/shared --path=/api -- bun run --filter @agent-artifacts/cli build:release",
    "cli:build:release:env-file": "bun --env-file=.env run --filter @agent-artifacts/cli build:release",
    "cli:install": "bun run cli:build && node scripts/install-cli.mjs",
    "cli:install:prod": "bun run cli:build:prod && node scripts/install-cli.mjs --prod",
    "railway:sync-env": "node scripts/sync-infisical-to-railway.mjs",
    "railway:sync-env:dry-run": "node scripts/sync-infisical-to-railway.mjs --dry-run",
    "artifacts": "node apps/cli/dist/cli.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "dotenv": "^16.6.1",
    "tsx": "^4.22.0",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
